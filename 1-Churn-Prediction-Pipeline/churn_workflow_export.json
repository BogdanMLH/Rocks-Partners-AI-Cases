      "parameters": {
        "jsCode": "return [\n  {\n    // Whale, long tenure — should be very LOW\n    json: {\n      player_ID: 201,\n      Average_Monthly_Deposit: 1500,\n      Months_Since_Registration: 72,\n      Lifetime_Value: 108000,\n      gmail: \"bohdanmalanchenko@gmail.com\"\n    }\n  },\n  {\n    // New high spender — short tenure makes it HIGH despite big deposits\n    json: {\n      player_ID: 202,\n      Average_Monthly_Deposit: 1200,\n      Months_Since_Registration: 2,\n      Lifetime_Value: 2400,\n      gmail: \"bohdanmalanchenko@gmail.com\"\n    }\n  },\n  {\n    // Classic churn profile — low deposit, barely registered\n    json: {\n      player_ID: 203,\n      Average_Monthly_Deposit: 20,\n      Months_Since_Registration: 1,\n      Lifetime_Value: 20\n    }\n  },\n  {\n    // Loyal small spender — low deposit but years of activity\n    json: {\n      player_ID: 204,\n      Average_Monthly_Deposit: 35,\n      Months_Since_Registration: 60,\n      Lifetime_Value: 2100\n    }\n  },\n  {\n    // Mid-tier player with healthy spend consistency\n    json: {\n      player_ID: 205,\n      Average_Monthly_Deposit: 250,\n      Months_Since_Registration: 24,\n      Lifetime_Value: 6000\n    }\n  },\n  {\n    // Declining spender — high lifetime but low current monthly vs total ratio\n    json: {\n      player_ID: 206,\n      Average_Monthly_Deposit: 50,\n      Months_Since_Registration: 48,\n      Lifetime_Value: 15000\n    }\n  },\n  {\n    // Rapid drop-off — was spending big, now almost nothing\n    json: {\n      player_ID: 207,\n      Average_Monthly_Deposit: 15,\n      Months_Since_Registration: 36,\n      Lifetime_Value: 9000\n    }\n  },\n  {\n    // Consistent mid spender, long tenure — should be LOW\n    json: {\n      player_ID: 208,\n      Average_Monthly_Deposit: 180,\n      Months_Since_Registration: 45,\n      Lifetime_Value: 8100\n    }\n  },\n  {\n    // Brand new, zero lifetime value — never deposited yet\n    json: {\n      player_ID: 209,\n      Average_Monthly_Deposit: 0,\n      Months_Since_Registration: 0,\n      Lifetime_Value: 0\n    }\n  },\n  {\n    // Short tenure but spend_per_month is perfectly consistent — borderline\n    json: {\n      player_ID: 210,\n      Average_Monthly_Deposit: 100,\n      Months_Since_Registration: 5,\n      Lifetime_Value: 500\n    }\n  },\n  {\n    // Very high monthly vs total ratio — newer player spending aggressively\n    json: {\n      player_ID: 211,\n      Average_Monthly_Deposit: 800,\n      Months_Since_Registration: 3,\n      Lifetime_Value: 2400\n    }\n  },\n  {\n    // Ghost player — registered long ago but almost no deposits\n    json: {\n      player_ID: 212,\n      Average_Monthly_Deposit: 10,\n      Months_Since_Registration: 50,\n      Lifetime_Value: 200\n    }\n  },\n  {\n    // Recovering player — low monthly but decent lifetime suggests recent drop\n    json: {\n      player_ID: 213,\n      Average_Monthly_Deposit: 40,\n      Months_Since_Registration: 30,\n      Lifetime_Value: 5500\n    }\n  },\n  {\n    // Perfect consistency — monthly * tenure = lifetime exactly\n    json: {\n      player_ID: 214,\n      Average_Monthly_Deposit: 200,\n      Months_Since_Registration: 30,\n      Lifetime_Value: 6000\n    }\n  },\n  {\n    // Mid spender, mid tenure — pure average player, tests model's middle ground\n    json: {\n      player_ID: 215,\n      Average_Monthly_Deposit: 120,\n      Months_Since_Registration: 18,\n      Lifetime_Value: 2160\n    }\n  },\n  {\n    // High deposit but suspiciously low lifetime — possible data issue\n    json: {\n      player_ID: 216,\n      Average_Monthly_Deposit: 900,\n      Months_Since_Registration: 24,\n      Lifetime_Value: 800\n    }\n  },\n  {\n    // Extreme whale — tests upper boundary of model confidence\n    json: {\n      player_ID: 217,\n      Average_Monthly_Deposit: 5000,\n      Months_Since_Registration: 60,\n      Lifetime_Value: 300000\n    }\n  },\n  {\n    // Long tenure, zero recent deposits — likely churned already\n    json: {\n      player_ID: 218,\n      Average_Monthly_Deposit: 0,\n      Months_Since_Registration: 55,\n      Lifetime_Value: 3200\n    }\n  },\n  {\n    // Borderline: medium everything, no strong signals either way\n    json: {\n      player_ID: 219,\n      Average_Monthly_Deposit: 90,\n      Months_Since_Registration: 12,\n      Lifetime_Value: 1080\n    }\n  },\n  {\n    // Negative Monthly_vs_Total edge — lifetime is 1 cent, stresses division guard\n    json: {\n      player_ID: 220,\n      Average_Monthly_Deposit: 500,\n      Months_Since_Registration: 1,\n      Lifetime_Value: 0.01\n    }\n  }\n];"
      },
