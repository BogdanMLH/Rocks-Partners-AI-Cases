      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst totalHigh = items.length;\nconst totalLTV = items.reduce((sum, i) => sum + (parseFloat(i.json.lifetime_Value) || 0), 0);\nconst avgRisk = items.reduce((sum, i) => sum + (parseFloat(i.json.churn_risk) || 0), 0) / totalHigh;\nconst highestRisk = items.reduce((a, b) => parseFloat(a.json.churn_risk) > parseFloat(b.json.churn_risk) ? a : b);\nconst highestLTV = items.reduce((a, b) => parseFloat(a.json.lifetime_Value) > parseFloat(b.json.lifetime_Value) ? a : b);\n\nreturn [{\n  json: {\n    total_high_risk: totalHigh,\n    total_ltv_at_risk: totalLTV.toFixed(2),\n    average_risk_score: avgRisk.toFixed(2),\n    highest_risk_player: {\n      player_ID: highestRisk.json.player_ID,\n      churn_risk: parseFloat(highestRisk.json.churn_risk),\n      lifetime_Value: parseFloat(highestRisk.json.lifetime_Value)\n    },\n    highest_ltv_player: {\n      player_ID: highestLTV.json.player_ID,\n      churn_risk: parseFloat(highestLTV.json.churn_risk),\n      lifetime_Value: parseFloat(highestLTV.json.lifetime_Value)\n    },\n    scan_date: new Date().toLocaleDateString('en-GB')\n  }\n}];"
      },
